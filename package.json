{
  "name": "palaxy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:errors": "eslint . --max-warnings=0",
    "lint:view": "eslint . --format codeframe",
    "lint:quotes": "eslint . --rule 'quotes: [\"error\", \"double\"]' --fix",
    "lint:errors-clean": "eslint . --format json | jq '.[] | .messages[] | select(.severity == 2)'",
    "prepare": "husky install",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.38.0",
    "next": "^16.2.5",
    "postcss": "^8.5.21",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.27",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-next": "16.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}